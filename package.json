{
  "name": "BlixtWallet",
  "version": "0.9.0",
  "private": true,
  "nodeLinker": "node-modules",
  "scripts": {
    "lint": "eslint .",
    "postinstall": "node scripts/fetch-lnd-if-needed.js",
    "start": "react-native start",
    "start-metro": "react-native start",
    "android:clean": "cd android && ./gradlew clean",
    "android:regtest-debug": "react-native run-android --mode chainregtestNormalDebug --appIdSuffix regtest.debug --main-activity MainActivity --extra-params=\"-PreactNativeArchitectures=arm64-v8a,x86_64\"",
    "android:regtest": "react-native run-android --mode chainregtestNormalRelease --appIdSuffix regtest --extra-params=\"-PreactNativeArchitectures=arm64-v8a,x86_64\"",
    "android:signet-debug": "react-native run-android --mode chainsignetNormalDebug --appIdSuffix signet.debug --main-activity MainActivity --extra-params=\"-PreactNativeArchitectures=arm64-v8a,x86_64\"",
    "android:signet": "react-native run-android --mode chainsignetNormalRelease --appIdSuffix signet --extra-params=\"-PreactNativeArchitectures=arm64-v8a,x86_64\"",
    "android:testnet-debug": "react-native run-android --mode chaintestnetNormalDebug --appIdSuffix testnet.debug --main-activity MainActivity --extra-params=\"-PreactNativeArchitectures=arm64-v8a,x86_64\"",
    "android:testnet": "react-native run-android --mode chaintestnetNormalRelease --appIdSuffix testnet --extra-params=\"-PreactNativeArchitectures=arm64-v8a,x86_64\"",
    "android:mainnet-debug": "react-native run-android --mode chainmainnetNormalDebug --appIdSuffix debug --main-activity MainActivity --extra-params=\"-PreactNativeArchitectures=arm64-v8a,x86_64\"",
    "android:mainnet": "react-native run-android --mode chainmainnetNormalRelease --extra-params=\"-PreactNativeArchitectures=arm64-v8a,x86_64\"",
    "android:mainnet-fakelnd": "react-native run-android --mode chainmainnetFakelndRelease --appIdSuffix fakelnd --extra-params=\"-PreactNativeArchitectures=arm64-v8a,x86_64\"",
    "android:mainnet-fakelnd-debug": "react-native run-android --mode chainmainnetFakelndDebug --appIdSuffix fakelnd.debug --extra-params=\"-PreactNativeArchitectures=arm64-v8a,x86_64\"",
    "android:bundle-release": "cd android && ./gradlew clean && ./gradlew bundleChainmainnetNormalRelease && ./gradlew bundleChaintestnetNormalRelease",
    "android:assemble-release": "cd android && ./gradlew clean && ./gradlew assembleChainmainnetNormalRelease && ./gradlew assembleChaintestnetNormalRelease",
    "android:bundle-release-mainnet": "cd android && ./gradlew clean && ./gradlew bundlechainmainnetNormalRelease",
    "android:bundle-release-testnet": "cd android && ./gradlew clean && ./gradlew bundlechaintestnetNormalRelease",
    "android:bundle-js-debug": "react-native bundle --platform android --dev true --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle",
    "android:bundle-js-release": "react-native bundle --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle",
    "ios:regtest-debug": "react-native run-ios --scheme BlixtWalletRegtest --configuration DebugRegtest",
    "ios:regtest": "react-native run-ios --scheme BlixtWalletRegtest --configuration ReleaseRegtest",
    "ios:testnet-debug": "react-native run-ios --scheme BlixtWalletTestnet --configuration DebugTestnet",
    "ios:testnet": "react-native run-ios --scheme BlixtWalletTestnet --configuration ReleaseTestnet",
    "ios:mainnet-debug": "react-native run-ios --scheme BlixtWallet --configuration Debug",
    "ios:mainnet": "react-native run-ios --scheme BlixtWallet --configuration Release",
    "ios:mainnet-fakelnd": "react-native run-ios --scheme BlixtWalletFakelnd --configuration ReleaseFakelnd",
    "ios:mainnet-fakelnd-debug": "react-native run-ios --scheme BlixtWalletFakelnd --configuration DebugFakelnd",
    "ios:bundle-js-release": "react-native bundle --platform ios --dev false --entry-file index.js --bundle-output ios/main.jsbundle",
    "macos:regtest-debug": "react-native-macos run-macos --scheme BlixtWalletRegtest --configuration DebugRegtest",
    "macos:regtest": "react-native-macos run-macos --scheme BlixtWalletRegtest --configuration ReleaseRegtest",
    "macos:testnet-debug": "react-native-macos run-macos --scheme BlixtWalletTestnet --configuration DebugTestnet",
    "macos:testnet": "react-native-macos run-macos --scheme BlixtWalletTestnet --configuration ReleaseTestnet",
    "macos:mainnet-debug": "react-native run-macos --scheme \"BlixtWallet Mainnet\" --configuration Debug",
    "macos:mainnet": "react-native-macos run-macos --scheme BlixtWallet --configuration Release",
    "macos:mainnet-fakelnd-debug": "react-native-macos run-macos --scheme BlixtWalletFakelnd --configuration DebugFakelnd",
    "macos:mainnet-fakelnd": "react-native-macos run-macos --scheme BlixtWalletFakelnd --configuration ReleaseFakelnd",
    "web": "cross-env BLIXT_DEV=false CHAIN=mainnet FLAVOR=fakelnd APPLICATION_ID=com.blixtwallet.web BLIXT_WEB_DEMO=false vite --config ./vite.config.ts",
    "web:demo": "cross-env BLIXT_DEV=false CHAIN=mainnet FLAVOR=fakelnd APPLICATION_ID=com.blixtwallet.web BLIXT_WEB_DEMO=true vite --config ./vite.config.ts",
    "web:debug": "cross-env BLIXT_DEV=true CHAIN=mainnet FLAVOR=fakelnd APPLICATION_ID=com.blixtwallet.web BLIXT_WEB_DEMO=false vite --config ./vite.config.ts",
    "web:bundle": "cross-env BLIXT_DEV=false NODE_ENV=production CHAIN=mainnet FLAVOR=fakelnd APPLICATION_ID=com.blixtwallet.web BLIXT_WEB_DEMO=false vite build --config ./vite.config.ts",
    "web:bundle:webdemo": "cross-env BLIXT_DEV=false NODE_ENV=production CHAIN=mainnet FLAVOR=fakelnd APPLICATION_ID=com.blixtwallet.webdemo BLIXT_WEB_DEMO=true vite build --config ./vite.config.ts",
    "web:preview": "vite preview --config ./vite.config.ts",
    "electrobun:bundle:normal": "cross-env BLIXT_DEV=true NODE_ENV=production CHAIN=mainnet FLAVOR=normal APPLICATION_ID=com.blixtwallet.electrobun BLIXT_WEB_DEMO=false VITE_IS_ELECTROBUN=true VITE_VERSION_NAME=0.9.0-electrobun vite build --config ./vite.config.ts --base ./ --outDir ../electrobun/src/mainview/dist --emptyOutDir",
    "electrobun:bundle:fakelnd": "cross-env BLIXT_DEV=true NODE_ENV=production CHAIN=mainnet FLAVOR=fakelnd APPLICATION_ID=com.blixtwallet.electrobun BLIXT_WEB_DEMO=false VITE_IS_ELECTROBUN=true VITE_VERSION_NAME=0.9.0-electrobun vite build --config ./vite.config.ts --base ./ --outDir ../electrobun/src/mainview/dist --emptyOutDir",
    "electrobun:bundle:package:normal": "cross-env BLIXT_DEV=false NODE_ENV=production CHAIN=mainnet FLAVOR=normal APPLICATION_ID=com.blixtwallet.electrobun BLIXT_WEB_DEMO=false VITE_IS_ELECTROBUN=true VITE_VERSION_NAME=0.9.0-electrobun vite build --config ./vite.config.ts --base ./ --outDir ../electrobun/src/mainview/dist --emptyOutDir",
    "electrobun:bundle:package:fakelnd": "cross-env BLIXT_DEV=false NODE_ENV=production CHAIN=mainnet FLAVOR=fakelnd APPLICATION_ID=com.blixtwallet.electrobun BLIXT_WEB_DEMO=false VITE_IS_ELECTROBUN=true VITE_VERSION_NAME=0.9.0-electrobun vite build --config ./vite.config.ts --base ./ --outDir ../electrobun/src/mainview/dist --emptyOutDir",
    "electrobun:dev:normal": "bun run electrobun:bundle:normal && cd electrobun && cross-env FLAVOR=normal bun run start",
    "electrobun:dev:fakelnd": "bun run electrobun:bundle:fakelnd && cd electrobun && cross-env FLAVOR=fakelnd bun run start",
    "electrobun:build:normal": "bun run electrobun:bundle:normal && cd electrobun && cross-env FLAVOR=normal bun run build",
    "electrobun:build:fakelnd": "bun run electrobun:bundle:fakelnd && cd electrobun && cross-env FLAVOR=fakelnd bun run build",
    "electrobun:package:normal": "bun run electrobun:bundle:package:normal && cd electrobun && cross-env FLAVOR=normal bun run package:stable",
    "electrobun:package:fakelnd": "bun run electrobun:bundle:package:fakelnd && cd electrobun && cross-env FLAVOR=fakelnd bun run package:stable",
    "electrobun:dev": "cd electrobun && bun run dev",
    "electrobun:build": "cd electrobun && bun run build"
  },
  "dependencies": {
    "@babel/plugin-proposal-nullish-coalescing-operator": "^7.18.6",
    "@babel/plugin-proposal-optional-chaining": "^7.21.0",
    "@babel/plugin-transform-export-namespace-from": "7.27.1",
    "@babel/polyfill": "^7.12.1",
    "@babel/preset-react": "7.28.5",
    "@babel/preset-typescript": "7.28.5",
    "@bufbuild/protobuf": "2.11.0",
    "@legendapp/list": "2.0.19",
    "@notifee/react-native": "^9.1.8",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-clipboard/clipboard": "1.16.3",
    "@react-native-community/geolocation": "3.4.0",
    "@react-native-community/push-notification-ios": "^1.11.0",
    "@react-native-community/slider": "5.2.0",
