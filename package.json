  "engines": {
    "node": ">= 22.11.0"
  },
  "reactNativePermissionsIOS": [
    "LocationAccuracy",
    "LocationWhenInUse",
    "Notifications",
    "Camera"
  ],
  "codegenConfig": {
    "name": "BlixtTurboModules",
    "type": "modules",
    "jsSrcsDir": "src/turbomodules",
    "android": {
      "javaPackageName": "com.blixtwallet"
    },
    "ios": {
      "modulesProvider": {
        "NativeSpeedloader": "NativeSpeedloaderModuleProvider"
      }
    }
  }
